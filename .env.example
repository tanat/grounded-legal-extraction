# --- Model access -----------------------------------------------------------
# Option A (recommended): Vercel AI Gateway.
# Bare model strings like "anthropic/claude-sonnet-4.5" route through the gateway
# when this key is set. Lets you swap providers without code changes.
AI_GATEWAY_API_KEY=

# Option B: talk to Anthropic directly instead of the gateway.
# If you use this, change src/config.ts to the @ai-sdk/anthropic provider.
# ANTHROPIC_API_KEY=
