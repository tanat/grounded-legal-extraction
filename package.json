{
  "name": "grounded-legal-extraction",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Grounded LLM extraction for German/Swiss legal documents — file upload, structured output, verifiable source highlighting, and an eval harness.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "extract": "tsx src/extraction/cli.ts",
    "eval": "tsx src/eval/harness.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ai": "^6.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "unpdf": "^0.12.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
